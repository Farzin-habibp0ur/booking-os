generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  phone                String?
  timezone             String   @default("UTC")
  verticalPack         String   @default("aesthetic")
  packConfig           Json     @default("{}")
  defaultLocale        String   @default("en")
  aiSettings           Json     @default("{}")
  notificationSettings Json     @default("{}")
  policySettings       Json     @default("{}")
  campaignPreferences  Json     @default("{}")
  logoUrl              String?
  brandPrimaryColor    String?  @default("#71907C")
  brandTagline         String?
  brandFaviconUrl      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  staff                Staff[]
  customers            Customer[]
  services             Service[]
  bookings             Booking[]
  recurringSeries      RecurringSeries[]
  conversations        Conversation[]
  reminders            Reminder[]
  messageTemplates     MessageTemplate[]
  translations         Translation[]
  subscription         Subscription?
  billingCredits       BillingCredit[]
  aiUsage              AiUsage[]
  roiBaselines         RoiBaseline[]
  waitlistEntries      WaitlistEntry[]
  automationRules      AutomationRule[]
  campaigns              Campaign[]
  campaignUnsubscribes   CampaignUnsubscribe[]
  offers                 Offer[]
  locations            Location[]
  quotes               Quote[]
  verticalPackVersions VerticalPackVersion[]
  savedViews           SavedView[]
  customerNotes        CustomerNote[]
  offerRedemptions     OfferRedemption[]
  actionCards          ActionCard[]
  actionHistory        ActionHistory[]
  autonomyConfigs      AutonomyConfig[]
  outboundDrafts       OutboundDraft[]
  agentConfigs         AgentConfig[]
  agentRuns            AgentRun[]
  agentFeedback        AgentFeedback[]
  duplicateCandidates  DuplicateCandidate[]
  messageAttachments   MessageAttachment[]
  viewAsSessions       ViewAsSession[]       @relation("ViewAsTarget")
  supportCases         SupportCase[]
  packTenantPins       PackTenantPin[]
  trialEndsAt          DateTime?
  graceEndsAt          DateTime?
  channelSettings      Json     @default("{}")

  messageUsage         MessageUsage[]
  customerReferrals    CustomerReferral[]
  customerCredits      CustomerCredit[]
  staffServicePrices   StaffServicePrice[]
  payments             Payment[]
  refunds              Refund[]
  contentDrafts              ContentDraft[]
  emailSequences             EmailSequence[]
  emailSequenceEnrollments   EmailSequenceEnrollment[]
  testimonials               Testimonial[]
  reportSchedules            ReportSchedule[]
  businessReviews            BusinessReview[]
  savedSegments              SavedSegment[]
  invoices                   Invoice[]
  medicalRecords             MedicalRecord[]
  clinicalPhotos             ClinicalPhoto[]
  photoComparisons           PhotoComparison[]
  treatmentPlans             TreatmentPlan[]
  aftercareProtocols         AftercareProtocol[]

  abTests                    ABTest[]
  rejectionLogs              RejectionLog[]
  platformConfigs            PlatformConfig[]
  budgetEntries              BudgetEntry[]
  escalationEvents           EscalationEvent[]
  deviceTokens               DeviceToken[]

  @@map("businesses")
}

model Staff {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  email         String   @unique
  passwordHash  String?
  role          String   @default("AGENT") // ADMIN, SERVICE_PROVIDER, AGENT
  locale        String?
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  preferences      Json    @default("{}")
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)
  backupCodes      Json    @default("[]")

  business            Business             @relation(fields: [businessId], references: [id])
  bookings            Booking[]
  recurringSeries     RecurringSeries[]
  conversations       Conversation[]       @relation("AssignedConversations")
  messages            Message[]            @relation("SentMessages")
  notes               ConversationNote[]   @relation("StaffNotes")
  customerNotes       CustomerNote[]       @relation("StaffCustomerNotes")
  workingHours        WorkingHours[]
  timeOff             TimeOff[]
  calendarConnections CalendarConnection[]
  waitlistEntries     WaitlistEntry[]      @relation("PreferredStaffWaitlist")
  staffLocations      StaffLocation[]
  savedViews          SavedView[]
  assignedActionCards ActionCard[]         @relation("AssignedActionCards")
  resolvedActionCards ActionCard[]         @relation("ResolvedActionCards")
  outboundDrafts      OutboundDraft[]      @relation("StaffOutboundDrafts")
  approvedOutbounds   OutboundDraft[]      @relation("ApprovedOutboundDrafts")
  agentFeedback       AgentFeedback[]
  viewAsSessions      ViewAsSession[]      @relation("ViewAsSuperAdmin")
  issuedCredits       BillingCredit[]      @relation("BillingCreditIssuer")
  packPins            PackTenantPin[]      @relation("PackPinStaff")
  staffServicePrices  StaffServicePrice[]
  medicalRecords      MedicalRecord[]  @relation("MedicalRecordStaff")
  clinicalPhotosTaken ClinicalPhoto[]  @relation("PhotoTakenByStaff")
  treatmentPlans      TreatmentPlan[]  @relation("TreatmentPlanCreator")

  rejectionLogReviews     RejectionLog[]      @relation("RejectionLogReviewer")
  resolvedEscalations     EscalationEvent[]   @relation("EscalationResolver")
  deviceTokens            DeviceToken[]

  @@index([businessId])
  @@map("staff")
}

model Customer {
  id                String    @id @default(cuid())
  businessId        String
  name              String
  phone             String
  email             String?
  instagramUserId   String?
  facebookPsid      String?
  webChatSessionId  String?
  tags              String[]  @default([])
  customFields      Json      @default("{}")
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  business              Business             @relation(fields: [businessId], references: [id])
  bookings              Booking[]
  recurringSeries       RecurringSeries[]
  conversations         Conversation[]
  waitlistEntries       WaitlistEntry[]
  customerNotes         CustomerNote[]
  offerRedemptions      OfferRedemption[]
  actionCards           ActionCard[]
  outboundDrafts        OutboundDraft[]
  duplicatesAsCustomer1 DuplicateCandidate[] @relation("DuplicateCustomer1")
  duplicatesAsCustomer2 DuplicateCandidate[] @relation("DuplicateCustomer2")
  payments              Payment[]
  testimonials            Testimonial[]
  campaignUnsubscribes    CampaignUnsubscribe[]
  invoices                Invoice[]
  medicalRecords          MedicalRecord[]
  clinicalPhotos          ClinicalPhoto[]
  photoComparisons      PhotoComparison[]
  treatmentPlans            TreatmentPlan[]
  aftercareEnrollments      AftercareEnrollment[]

  referralCode              String?   @unique
  referralsGiven            CustomerReferral[] @relation("ReferrerCustomer")
  referralsReceived         CustomerReferral[] @relation("ReferredCustomer")
  credits                   CustomerCredit[]

  @@unique([businessId, phone])
  @@unique([businessId, instagramUserId])
  @@unique([businessId, facebookPsid])
  @@unique([businessId, webChatSessionId])
  @@index([businessId])
  @@index([businessId, email])
  @@index([businessId, phone])
  @@map("customers")
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  description     String?
  durationMins    Int
  price           Float    @default(0)
  category        String   @default("General")
  kind            String   @default("OTHER") // CONSULT, TREATMENT, OTHER
  isActive        Boolean  @default(true)
  depositRequired       Boolean  @default(false)
  depositAmount         Float?
  bufferBefore          Int      @default(0)
  bufferAfter           Int      @default(0)
  requiredResourceType  String?
  maxParticipants       Int      @default(1)
  requiresCertification String?
  customFields          Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  business           Business            @relation(fields: [businessId], references: [id])
  bookings           Booking[]
  recurringSeries    RecurringSeries[]
  waitlistEntries    WaitlistEntry[]
  staffServicePrices  StaffServicePrice[]
  invoiceLineItems    InvoiceLineItem[]
  treatmentSessions    TreatmentSession[]
  aftercareProtocols   AftercareProtocol[]

  @@index([businessId])
  @@map("services")
}

model Booking {
  id                      String   @id @default(cuid())
  businessId              String
  customerId              String
  serviceId               String
  staffId                 String?
  conversationId          String?
  recurringSeriesId       String?
  locationId              String?
  resourceId              String?

  status                  String   @default("PENDING")
  startTime               DateTime
  endTime                 DateTime
  notes                   String?
  externalCalendarEventId String?
  customFields            Json     @default("{}")
  colorLabel              String?
  source                  String   @default("MANUAL")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  business        Business         @relation(fields: [businessId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  service         Service          @relation(fields: [serviceId], references: [id])
  staff           Staff?           @relation(fields: [staffId], references: [id])
  conversation    Conversation?    @relation(fields: [conversationId], references: [id])
  recurringSeries RecurringSeries? @relation(fields: [recurringSeriesId], references: [id])
  location        Location?        @relation(fields: [locationId], references: [id])
  resource        Resource?        @relation(fields: [resourceId], references: [id])
  reminders       Reminder[]
  payments        Payment[]
  quotes          Quote[]
  actionCards     ActionCard[]
  invoices        Invoice[]
  clinicalPhotos  ClinicalPhoto[]
  consultPlan          TreatmentPlan?        @relation("ConsultPlan")
  sessionBooking       TreatmentSession?     @relation("SessionBooking")
  aftercareEnrollment  AftercareEnrollment?

  referral             CustomerReferral?
  creditRedemptions    CreditRedemption[]

  @@index([businessId])
  @@index([businessId, startTime])
  @@index([businessId, status])
  @@index([businessId, startTime, status])
  @@index([businessId, source])
  @@index([locationId])
  @@index([resourceId])
  @@map("bookings")
}

model RecurringSeries {
  id            String    @id @default(cuid())
  businessId    String
  customerId    String
  serviceId     String
  staffId       String?
  timeOfDay     String
  daysOfWeek    Int[]
  intervalWeeks Int       @default(1)
  totalCount    Int
  endsAt        DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business Business  @relation(fields: [businessId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  service  Service   @relation(fields: [serviceId], references: [id])
  staff    Staff?    @relation(fields: [staffId], references: [id])
  bookings Booking[]

  @@index([businessId])
  @@map("recurring_series")
}

model Conversation {
  id            String    @id @default(cuid())
  businessId    String
  customerId    String
  assignedToId  String?
  locationId    String?
  channel       String    @default("WHATSAPP")
  status        String    @default("OPEN")
  lastMessageAt      DateTime?
  lastInboundChannel String?
  snoozedUntil       DateTime?
  tags          String[]  @default([])
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business       Business           @relation(fields: [businessId], references: [id])
  customer       Customer           @relation(fields: [customerId], references: [id])
  assignedTo     Staff?             @relation("AssignedConversations", fields: [assignedToId], references: [id])
  location       Location?          @relation(fields: [locationId], references: [id])
  messages       Message[]
  bookings       Booking[]
  notes          ConversationNote[]
  actionCards    ActionCard[]
  outboundDrafts OutboundDraft[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([locationId])
  @@index([customerId, businessId])
  @@index([businessId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  direction      String
  senderStaffId  String?
  content        String
  contentType    String    @default("TEXT")
  channel        String    @default("WHATSAPP")
  externalId     String?   @unique
  deliveryStatus String    @default("SENT") // SENT, DELIVERED, READ, FAILED, SCHEDULED, CANCELLED
  deliveredAt    DateTime?
  readAt         DateTime?
  failureReason  String?
  scheduledFor   DateTime?
  scheduledJobId String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())

  conversation Conversation        @relation(fields: [conversationId], references: [id])
  senderStaff  Staff?              @relation("SentMessages", fields: [senderStaffId], references: [id])
  attachments  MessageAttachment[]

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model Reminder {
  id          String    @id @default(cuid())
  businessId  String
  bookingId   String
  templateId  String?
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("PENDING")
  type        String    @default("REMINDER")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business         @relation(fields: [businessId], references: [id])
  booking  Booking          @relation(fields: [bookingId], references: [id])
  template MessageTemplate? @relation(fields: [templateId], references: [id])

  @@index([businessId])
  @@index([status, scheduledAt])
  @@map("reminders")
}

model MessageTemplate {
  id         String   @id @default(cuid())
  businessId String
  name       String
  category   String   @default("CUSTOM")
  body       String
  variables  String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business  Business   @relation(fields: [businessId], references: [id])
  reminders Reminder[]

  @@index([businessId])
  @@map("message_templates")
}

model ConversationNote {
  id             String   @id @default(cuid())
  conversationId String
  staffId        String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  staff        Staff        @relation("StaffNotes", fields: [staffId], references: [id])

  @@index([conversationId])
  @@map("conversation_notes")
}

model WorkingHours {
  id        String  @id @default(cuid())
  staffId   String
  dayOfWeek Int // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime String // "09:00" (HH:mm format)
  endTime   String // "17:00" (HH:mm format)
  isOff     Boolean @default(false)

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, dayOfWeek])
  @@map("working_hours")
}

model TimeOff {
  id        String   @id @default(cuid())
  staffId   String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@map("time_off")
}

model Translation {
  id         String   @id @default(cuid())
  businessId String
  locale     String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, locale, key])
  @@index([businessId, locale])
  @@map("translations")
}

model Subscription {
  id                   String    @id @default(cuid())
  businessId           String    @unique
  stripeCustomerId     String
  stripeSubscriptionId String    @unique
  plan                 String    @default("starter") // starter, professional, enterprise
  status               String    @default("active") // active, past_due, canceled, trialing
  currentPeriodEnd     DateTime
  canceledAt           DateTime?
  cancelReason         String?
  planChangedAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model BillingCredit {
  id         String    @id @default(cuid())
  businessId String
  issuedById String
  amount     Float
  reason     String
  expiresAt  DateTime?
  appliedAt  DateTime?
  stripeId   String?
  createdAt  DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id])
  issuedBy Staff    @relation("BillingCreditIssuer", fields: [issuedById], references: [id])

  @@index([businessId])
  @@index([issuedById])
  @@map("billing_credits")
}

model Payment {
  id                    String   @id @default(cuid())
  businessId            String
  bookingId             String?
  customerId            String?
  invoiceId             String?
  amount                Float
  currency              String   @default("usd")
  method                String   @default("STRIPE") // CASH, CARD, BANK_TRANSFER, STRIPE, OTHER
  status                String   @default("COMPLETED") // COMPLETED, REFUNDED, PARTIAL_REFUND, pending, succeeded, failed
  reference             String?  // receipt number or external ref
  notes                 String?
  recordedById          String?  // staffId who recorded it
  stripePaymentIntentId String?  @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  business        Business         @relation(fields: [businessId], references: [id])
  booking         Booking?         @relation(fields: [bookingId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  refunds         Refund[]

  @@index([businessId])
  @@index([bookingId])
  @@index([invoiceId])
  @@map("payments")
}

model Refund {
  id             String    @id @default(cuid())
  businessId     String
  paymentId      String
  amount         Float
  reason         String?
  status         String    @default("PENDING") // PENDING, COMPLETED, FAILED
  stripeRefundId String?
  processedById  String
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id])
  payment  Payment  @relation(fields: [paymentId], references: [id])

  @@index([businessId])
  @@index([paymentId])
  @@map("refunds")
}

model AiUsage {
  id         String   @id @default(cuid())
  businessId String
  date       String // "2024-01-15" format
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, date])
  @@index([businessId])
  @@map("ai_usage")
}

model Token {
  id         String    @id @default(cuid())
  token      String    @unique
  type       String // PASSWORD_RESET, STAFF_INVITE, RESCHEDULE_LINK, CANCEL_LINK, EMAIL_VERIFY
  email      String
  businessId String?
  staffId    String?
  bookingId  String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([token])
  @@index([email, type])
  @@index([bookingId, type])
  @@map("tokens")
}

model RoiBaseline {
  id            String   @id @default(cuid())
  businessId    String
  goLiveDate    DateTime
  baselineStart DateTime
  baselineEnd   DateTime
  metrics       Json
  createdAt     DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@map("roi_baselines")
}

model CalendarConnection {
  id                     String    @id @default(cuid())
  staffId                String
  provider               String // "google", "outlook"
  accessToken            String // encrypted AES-256-GCM
  refreshToken           String // encrypted AES-256-GCM
  tokenExpiresAt         DateTime?
  calendarId             String? // e.g. "primary" for Google
  icalFeedToken          String?   @unique // random token for iCal feed URL
  icalFeedTokenExpiresAt DateTime?
  syncEnabled            Boolean   @default(true)
  lastSyncedAt           DateTime?
  lastSyncError          String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, provider])
  @@index([staffId])
  @@map("calendar_connections")
}

model WaitlistEntry {
  id              String    @id @default(cuid())
  businessId      String
  customerId      String
  serviceId       String
  staffId         String?
  timeWindowStart String?
  timeWindowEnd   String?
  dateFrom        DateTime?
  dateTo          DateTime?
  notes           String?
  status          String    @default("ACTIVE") // ACTIVE, OFFERED, BOOKED, EXPIRED, CANCELLED
  offeredAt       DateTime?
  offerExpiresAt  DateTime?
  offeredSlot     Json?
  claimedAt       DateTime?
  bookingId       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  staff    Staff?   @relation("PreferredStaffWaitlist", fields: [staffId], references: [id])

  @@index([businessId, status])
  @@index([businessId, serviceId, status])
  @@map("waitlist_entries")
}

model AutomationRule {
  id                   String   @id @default(cuid())
  businessId           String
  name                 String
  trigger              String // BOOKING_CREATED, BOOKING_UPCOMING, STATUS_CHANGED, BOOKING_CANCELLED, MESSAGE_RECEIVED, CUSTOMER_CREATED, PAYMENT_RECEIVED, TESTIMONIAL_SUBMITTED, CAMPAIGN_SENT
  filters              Json     @default("{}")
  actions              Json     @default("[]")
  isActive             Boolean  @default(true)
  playbook             String?
  quietStart           String?
  quietEnd             String?
  maxPerCustomerPerDay Int      @default(3)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business   Business              @relation(fields: [businessId], references: [id])
  logs       AutomationLog[]
  steps      AutomationStep[]
  executions AutomationExecution[]

  @@unique([businessId, name])
  @@index([businessId, isActive])
  @@map("automation_rules")
}

model AutomationLog {
  id               String   @id @default(cuid())
  automationRuleId String
  businessId       String
  bookingId        String?
  customerId       String?
  conversationId   String?
  action           String
  outcome          String // SENT, SKIPPED, FAILED
  reason           String?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())

  rule AutomationRule @relation(fields: [automationRuleId], references: [id])

  @@index([businessId, createdAt])
  @@index([automationRuleId])
  @@map("automation_logs")
}

model Campaign {
  id                String    @id @default(cuid())
  businessId        String
  name              String
  status            String    @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, CANCELLED
  templateId        String?
  filters           Json      @default("{}")
  scheduledAt       DateTime?
  sentAt            DateTime?
  throttlePerMinute Int       @default(10)
  stats             Json      @default("{}")
  recurrenceRule    String    @default("NONE") // NONE, DAILY, WEEKLY, BIWEEKLY, MONTHLY
  nextRunAt         DateTime?
  parentCampaignId  String?
  isABTest          Boolean   @default(false)
  variants          Json      @default("[]")
  winnerVariantId   String?
  winnerSelectedAt    DateTime?
  winnerMetric        String?    // READ_RATE or BOOKING_RATE
  testDurationMinutes Int?       // How long to run test phase (e.g. 120, 360, 720, 1440)
  testAudiencePercent Int?       @default(20) // % of audience in test phase (10-50)
  testPhaseEndsAt     DateTime?  // When the test phase window closes
  autoWinnerSelected  Boolean    @default(false) // Whether system auto-picked the winner
  channel             String?    @default("WHATSAPP") // WHATSAPP, SMS, EMAIL, MULTI
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  business       Business              @relation(fields: [businessId], references: [id])
  sends          CampaignSend[]
  unsubscribes   CampaignUnsubscribe[]
  parentCampaign Campaign?             @relation("CampaignRecurrence", fields: [parentCampaignId], references: [id])
  childCampaigns Campaign[]            @relation("CampaignRecurrence")

  @@unique([businessId, name])
  @@index([businessId])
  @@index([parentCampaignId])
  @@map("campaigns")
}

model CampaignSend {
  id         String    @id @default(cuid())
  campaignId String
  customerId String
  status     String    @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  sentAt     DateTime?
  bookingId  String?
  variantId  String?
  channel    String?   // WHATSAPP, SMS, EMAIL — actual channel used for this send
  openedAt   DateTime?
  createdAt  DateTime  @default(now())

  campaign Campaign        @relation(fields: [campaignId], references: [id])
  clicks   CampaignClick[]

  @@index([campaignId, status])
  @@map("campaign_sends")
}

model CampaignClick {
  id             String   @id @default(cuid())
  campaignSendId String
  url            String
  clickedAt      DateTime @default(now())
  userAgent      String?

  campaignSend CampaignSend @relation(fields: [campaignSendId], references: [id])

  @@index([campaignSendId])
  @@map("campaign_clicks")
}

model CampaignUnsubscribe {
  id         String    @id @default(cuid())
  businessId String
  customerId String
  campaignId String?   // Null = global unsubscribe from all campaigns
  token      String    @unique
  createdAt  DateTime  @default(now())

  business   Business  @relation(fields: [businessId], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  @@unique([businessId, customerId, campaignId])
  @@index([businessId, customerId])
  @@index([token])
  @@map("campaign_unsubscribes")
}

model Offer {
  id                 String    @id @default(cuid())
  businessId         String
  name               String
  description        String?
  terms              String?
  serviceIds         String[]  @default([])
  validFrom          DateTime?
  validUntil         DateTime?
  isActive           Boolean   @default(true)
  maxRedemptions     Int?
  currentRedemptions Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  business    Business          @relation(fields: [businessId], references: [id])
  redemptions OfferRedemption[]

  @@index([businessId])
  @@map("offers")
}

model OfferRedemption {
  id         String   @id @default(cuid())
  offerId    String
  customerId String
  businessId String
  createdAt  DateTime @default(now())

  offer    Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@unique([offerId, customerId])
  @@index([offerId])
  @@index([customerId])
  @@map("offer_redemptions")
}

model Location {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  address         String?
  isBookable      Boolean  @default(true)
  whatsappConfig  Json?
  instagramConfig Json?
  facebookConfig  Json?
  smsConfig       Json?
  emailConfig     Json?
  webChatConfig   Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business         Business         @relation(fields: [businessId], references: [id])
  bookings         Booking[]
  resources        Resource[]
  staffLocations   StaffLocation[]
  conversations    Conversation[]

  @@index([businessId])
  @@map("locations")
}

model Resource {
  id         String   @id @default(cuid())
  locationId String
  name       String
  type       String
  isActive   Boolean  @default(true)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location         Location         @relation(fields: [locationId], references: [id])
  bookings         Booking[]

  @@index([locationId])
  @@index([type])
  @@map("resources")
}

model StaffLocation {
  id         String @id @default(cuid())
  staffId    String
  locationId String

  staff    Staff    @relation(fields: [staffId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([staffId, locationId])
  @@map("staff_locations")
}

model VerticalPackVersion {
  id                 String    @id @default(cuid())
  businessId         String?
  slug               String
  version            Int       @default(1)
  name               String
  description        String?
  config             Json
  isPublished        Boolean   @default(false)
  rolloutStage       String    @default("draft")
  rolloutPercent     Int       @default(0)
  rolloutStartedAt   DateTime?
  rolloutCompletedAt DateTime?
  rolloutPausedAt    DateTime?
  rolledBackAt       DateTime?
  rolledBackReason   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  business Business? @relation(fields: [businessId], references: [id])

  @@unique([slug, version])
  @@index([slug])
  @@map("vertical_pack_versions")
}

model PackTenantPin {
  id            String   @id @default(cuid())
  businessId    String
  packSlug      String
  pinnedVersion Int
  reason        String
  pinnedById    String
  createdAt     DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  pinnedBy Staff    @relation("PackPinStaff", fields: [pinnedById], references: [id])

  @@unique([businessId, packSlug])
  @@index([packSlug])
  @@map("pack_tenant_pins")
}

model Quote {
  id          String    @id @default(cuid())
  bookingId   String
  businessId  String
  description String
  totalAmount Float
  pdfUrl      String?
  status      String    @default("PENDING")
  approvedAt  DateTime?
  approverIp  String?
  tokenId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])
  business Business @relation(fields: [businessId], references: [id])
  invoice  Invoice?

  @@index([bookingId])
  @@index([businessId])
  @@map("quotes")
}

model SavedView {
  id          String   @id @default(cuid())
  businessId  String
  staffId     String?
  page        String
  name        String
  filters     Json
  icon        String?
  color       String?
  isPinned    Boolean  @default(false)
  isDashboard Boolean  @default(false)
  sortOrder   Int      @default(0)
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])
  staff    Staff?   @relation(fields: [staffId], references: [id])

  @@index([businessId, staffId])
  @@index([businessId, isShared])
  @@index([businessId, page])
  @@map("saved_views")
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  staffId    String
  businessId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  staff    Staff    @relation("StaffCustomerNotes", fields: [staffId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@index([customerId])
  @@index([businessId])
  @@map("customer_notes")
}

model ActionCard {
  id              String    @id @default(cuid())
  businessId      String
  type            String // DEPOSIT_PENDING, OVERDUE_REPLY, OPEN_SLOT, STALLED_QUOTE, NO_SHOW_RISK, RETENTION_DUE, WAITLIST_MATCH, DATA_HYGIENE, SCHEDULE_GAP, QUOTE_FOLLOWUP
  category        String // URGENT_TODAY, NEEDS_APPROVAL, OPPORTUNITY, HYGIENE
  priority        Int       @default(50) // 0-100
  title           String
  description     String // "Because..." text
  suggestedAction String?
  preview         Json? // JSON diff / before-after
  ctaConfig       Json      @default("[]") // buttons array [{label, action, variant}]
  status          String    @default("PENDING") // PENDING, APPROVED, DISMISSED, SNOOZED, EXECUTED, EXPIRED
  autonomyLevel   String    @default("ASSISTED") // OFF, ASSISTED, AUTO
  snoozedUntil    DateTime?
  expiresAt       DateTime?
  bookingId       String?
  customerId      String?
  conversationId  String?
  staffId         String?
  resolvedById    String?
  resolvedAt      DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business     Business        @relation(fields: [businessId], references: [id])
  booking      Booking?        @relation(fields: [bookingId], references: [id])
  customer     Customer?       @relation(fields: [customerId], references: [id])
  conversation Conversation?   @relation(fields: [conversationId], references: [id])
  staff        Staff?          @relation("AssignedActionCards", fields: [staffId], references: [id])
  resolvedBy   Staff?          @relation("ResolvedActionCards", fields: [resolvedById], references: [id])
  feedback     AgentFeedback[]

  @@index([businessId, status])
  @@index([businessId, category, status])
  @@index([businessId, staffId, status])
  @@index([businessId, type, status])
  @@index([expiresAt])
  @@map("action_cards")
}

model ActionHistory {
  id          String   @id @default(cuid())
  businessId  String
  actorType   String // STAFF, AI, SYSTEM, CUSTOMER
  actorId     String?
  actorName   String?
  action      String // BOOKING_CREATED, BOOKING_UPDATED, BOOKING_CANCELLED, BOOKING_STATUS_CHANGED, CONVERSATION_ASSIGNED, CONVERSATION_STATUS_CHANGED, CARD_APPROVED, CARD_DISMISSED, CARD_EXECUTED, SETTING_CHANGED
  entityType  String // BOOKING, CONVERSATION, CUSTOMER, ACTION_CARD, SETTING
  entityId    String
  description String?
  diff        Json? // {before, after}
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId, createdAt])
  @@index([businessId, entityType, entityId])
  @@index([businessId, actorId])
  @@map("action_history")
}

model AutonomyConfig {
  id            String   @id @default(cuid())
  businessId    String
  actionType    String // matches ActionCard.type or "*" for default
  autonomyLevel String   @default("ASSISTED") // OFF, ASSISTED, AUTO
  requiredRole  String?
  constraints   Json     @default("{}") // {maxPerDay, maxAmount, etc.}
  scope         String   @default("OPERATIONAL") // OPERATIONAL, MARKETING
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, actionType, scope])
  @@index([businessId])
  @@map("autonomy_configs")
}

model OutboundDraft {
  id              String    @id @default(cuid())
  businessId      String
  customerId      String
  staffId         String
  channel         String    @default("WHATSAPP")
  content         String
  subject         String?
  status          String    @default("DRAFT") // DRAFT, APPROVED, SENT, REJECTED
  approvedById    String?
  sentAt          DateTime?
  conversationId  String?
  source          String    @default("MANUAL") // MANUAL, AI, AGENT
  sourceMessageId String?
  intent          String?
  confidence      Float?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business     Business      @relation(fields: [businessId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  staff        Staff         @relation("StaffOutboundDrafts", fields: [staffId], references: [id])
  approvedBy   Staff?        @relation("ApprovedOutboundDrafts", fields: [approvedById], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@index([businessId, status])
  @@index([businessId, customerId])
  @@unique([conversationId, channel, staffId])
  @@index([businessId, conversationId, status])
  @@map("outbound_drafts")
}

model AgentConfig {
  id             String   @id @default(cuid())
  businessId     String
  agentType      String // WAITLIST, RETENTION, DATA_HYGIENE, SCHEDULING_OPTIMIZER, QUOTE_FOLLOWUP
  isEnabled      Boolean  @default(false)
  autonomyLevel  String   @default("SUGGEST") // AUTO, SUGGEST, REQUIRE_APPROVAL
  config         Json     @default("{}")
  roleVisibility     String[] @default([])
  runIntervalMinutes Int?
  lastRunAt          DateTime?
  nextRunAt          DateTime?
  performanceScore   Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, agentType])
  @@index([businessId])
  @@map("agent_configs")
}

model AgentRun {
  id           String    @id @default(cuid())
  businessId   String
  agentType    String
  status       String    @default("RUNNING") // RUNNING, COMPLETED, FAILED
  cardsCreated Int       @default(0)
  error        String?
  errors       Json?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId, agentType])
  @@index([businessId, startedAt])
  @@index([businessId, agentType, status])
  @@map("agent_runs")
}

model AgentFeedback {
  id           String   @id @default(cuid())
  businessId   String
  actionCardId String
  staffId      String
  rating       String // HELPFUL, NOT_HELPFUL
  comment      String?
  createdAt    DateTime @default(now())

  business   Business   @relation(fields: [businessId], references: [id])
  actionCard ActionCard @relation(fields: [actionCardId], references: [id])
  staff      Staff      @relation(fields: [staffId], references: [id])

  @@unique([actionCardId, staffId])
  @@index([businessId])
  @@map("agent_feedback")
}

model MessageAttachment {
  id           String   @id @default(cuid())
  messageId    String
  businessId   String
  fileName     String
  fileType     String // MIME type
  fileSize     Int
  storageKey   String
  thumbnailKey String?
  createdAt    DateTime @default(now())

  message  Message  @relation(fields: [messageId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@index([messageId])
  @@index([businessId])
  @@map("message_attachments")
}

model DuplicateCandidate {
  id          String    @id @default(cuid())
  businessId  String
  customerId1 String
  customerId2 String
  confidence  Float
  matchFields String[]  @default([])
  status      String    @default("PENDING") // PENDING, MERGED, NOT_DUPLICATE, SNOOZED
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business  Business @relation(fields: [businessId], references: [id])
  customer1 Customer @relation("DuplicateCustomer1", fields: [customerId1], references: [id])
  customer2 Customer @relation("DuplicateCustomer2", fields: [customerId2], references: [id])

  @@unique([businessId, customerId1, customerId2])
  @@index([businessId, status])
  @@map("duplicate_candidates")
}

model ViewAsSession {
  id               String    @id @default(cuid())
  superAdminId     String
  targetBusinessId String
  reason           String
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  expiresAt        DateTime
  actionsLog       Json      @default("[]")
  createdAt        DateTime  @default(now())

  superAdmin     Staff    @relation("ViewAsSuperAdmin", fields: [superAdminId], references: [id])
  targetBusiness Business @relation("ViewAsTarget", fields: [targetBusinessId], references: [id])

  @@index([superAdminId])
  @@index([targetBusinessId])
  @@map("view_as_sessions")
}

model PlatformAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  targetType String?
  targetId   String?
  reason     String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@map("platform_audit_logs")
}

model SupportCase {
  id           String    @id @default(cuid())
  businessId   String
  businessName String
  subject      String
  description  String
  status       String    @default("open") // open, in_progress, resolved, closed
  priority     String    @default("normal") // low, normal, high, urgent
  category     String?
  resolution   String?
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business          @relation(fields: [businessId], references: [id])
  notes    SupportCaseNote[]

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("support_cases")
}

model SupportCaseNote {
  id         String   @id @default(cuid())
  caseId     String
  authorId   String
  authorName String
  content    String
  createdAt  DateTime @default(now())

  supportCase SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("support_case_notes")
}

model PlatformAgentDefault {
  id                  String   @id @default(cuid())
  agentType           String   @unique // WAITLIST, RETENTION, DATA_HYGIENE, SCHEDULING_OPTIMIZER, QUOTE_FOLLOWUP
  maxAutonomyLevel    String   @default("SUGGEST") // AUTO, SUGGEST, REQUIRE_APPROVAL
  defaultEnabled      Boolean  @default(false)
  confidenceThreshold Float    @default(0.7)
  requiresReview      Boolean  @default(true)
  updatedAt           DateTime @updatedAt
  updatedById         String?

  @@map("platform_agent_defaults")
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_settings")
}


model StaffServicePrice {
  id         String   @id @default(cuid())
  staffId    String
  serviceId  String
  businessId String
  price      Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  staff    Staff    @relation(fields: [staffId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@unique([staffId, serviceId])
  @@index([businessId])
  @@index([staffId])
  @@map("staff_service_prices")
}

model ContentDraft {
  id            String    @id @default(uuid())
  businessId    String
  title         String
  body          String    @db.Text
  contentType   String
  channel       String
  pillar        String?
  status        String    @default("PENDING_REVIEW")
  agentId       String?
  scheduledFor  DateTime?
  publishedAt   DateTime?
  reviewedById  String?
  reviewNote    String?
  metadata        Json?
  tier            String?   // GREEN, YELLOW, RED
  slug            String?
  qualityScore    Int?      // 0-100
  rejectionCode   String?   // R01-R10
  rejectionReason String?
  currentGate     String?   // GATE_1, GATE_2, GATE_3, GATE_4
  platform        String?   // INSTAGRAM, TIKTOK, LINKEDIN, YOUTUBE, PINTEREST, TWITTER, BLOG
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business       Business        @relation(fields: [businessId], references: [id])
  rejectionLogs  RejectionLog[]
  abTestVariants ABTestVariant[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, tier])
  @@index([businessId, currentGate])
  @@map("content_drafts")
}

model EmailSequence {
  id           String   @id @default(cuid())
  businessId   String?
  name         String
  type         String
  isActive     Boolean  @default(true)
  steps        Json     @default("[]")
  triggerEvent String?
  stopOnEvent  String?
  metadata     Json     @default("{}")
  metrics      Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business    Business?                @relation(fields: [businessId], references: [id])
  enrollments EmailSequenceEnrollment[]

  @@index([businessId])
  @@index([type])
  @@map("email_sequences")
}

model EmailSequenceEnrollment {
  id          String    @id @default(cuid())
  sequenceId  String
  businessId  String
  email       String
  name        String
  currentStep Int       @default(0)
  status      String    @default("ACTIVE")
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  cancelledAt DateTime?
  metadata    Json      @default("{}")

  sequence EmailSequence @relation(fields: [sequenceId], references: [id])
  business Business      @relation(fields: [businessId], references: [id])

  @@unique([sequenceId, businessId, email])
  @@index([sequenceId, status])
  @@index([businessId])
  @@map("email_sequence_enrollments")
}

model Testimonial {
  id              String    @id @default(cuid())
  businessId      String
  customerId      String?
  name            String
  role            String?
  company         String?
  content         String    @db.Text
  rating          Int?
  status          String    @default("PENDING")
  source          String    @default("MANUAL")
  requestedAt     DateTime?
  submittedAt     DateTime?
  submissionToken String?   @unique
  reminderSentAt  DateTime?
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business Business  @relation(fields: [businessId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([businessId, status])
  @@map("testimonials")
}

model ReportSchedule {
  id          String    @id @default(cuid())
  businessId  String
  reportType  String    // bookings-over-time, revenue-over-time, no-show-rate, etc.
  frequency   String    // DAILY, WEEKLY, MONTHLY
  recipients  String[]  // email addresses
  dayOfWeek   Int?      // 0-6 (Sun-Sat) for WEEKLY
  dayOfMonth  Int?      // 1-28 for MONTHLY
  hour        Int       @default(9) // 0-23 UTC
  timezone    String    @default("UTC")
  isActive    Boolean   @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([isActive, frequency])
  @@map("report_schedules")
}

model BusinessReview {
  id          String   @id @default(uuid())
  businessId  String
  month       String   // YYYY-MM
  metrics     Json
  aiSummary   String   @db.Text
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, month])
  @@index([businessId])
  @@map("business_reviews")
}

model AutomationStep {
  id               String   @id @default(cuid())
  automationRuleId String
  order            Int
  type             String // ACTION, DELAY, BRANCH
  config           Json     @default("{}")
  parentStepId     String?
  branchLabel      String?
  createdAt        DateTime @default(now())

  automationRule AutomationRule   @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  parentStep     AutomationStep?  @relation("StepBranch", fields: [parentStepId], references: [id])
  childSteps     AutomationStep[] @relation("StepBranch")
  executions     AutomationExecution[]

  @@index([automationRuleId, order])
  @@map("automation_steps")
}

model AutomationExecution {
  id               String    @id @default(cuid())
  automationRuleId String
  stepId           String?
  businessId       String
  customerId       String?
  bookingId        String?
  status           String    @default("PENDING") // PENDING, RUNNING, WAITING, COMPLETED, FAILED, SKIPPED
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  error            String?
  context          Json      @default("{}")
  createdAt        DateTime  @default(now())

  automationRule AutomationRule  @relation(fields: [automationRuleId], references: [id])
  step           AutomationStep? @relation(fields: [stepId], references: [id])

  @@index([automationRuleId, status])
  @@index([status, scheduledAt])
  @@map("automation_executions")
}

model SavedSegment {
  id         String   @id @default(cuid())
  businessId String
  name       String
  filters    Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@map("saved_segments")
}

model BookingAuditLog {
  id        String   @id @default(cuid())
  bookingId String
  businessId String
  userId    String?
  userName  String?
  action    String // CREATED, UPDATED, RESCHEDULED, CANCELLED, STATUS_CHANGED, PAYMENT_RECEIVED, NOTE_ADDED
  changes   Json     @default("[]")
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([businessId, createdAt])
  @@map("booking_audit_logs")
}

model Invoice {
  id             String    @id @default(cuid())
  businessId     String
  customerId     String
  bookingId      String?
  quoteId        String?   @unique
  invoiceNumber  String
  status         String    @default("DRAFT") // DRAFT, SENT, VIEWED, PAID, PARTIALLY_PAID, OVERDUE, CANCELLED, REFUNDED
  subtotal       Decimal   @db.Decimal(10, 2)
  taxRate        Decimal?  @db.Decimal(5, 4)
  taxAmount      Decimal?  @db.Decimal(10, 2)
  discountAmount Decimal?  @db.Decimal(10, 2)
  total          Decimal   @db.Decimal(10, 2)
  currency       String    @default("USD")
  dueDate        DateTime
  paidAmount     Decimal   @default(0) @db.Decimal(10, 2)
  notes          String?
  terms          String?
  pdfUrl         String?
  sentAt         DateTime?
  viewedAt       DateTime?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  business  Business          @relation(fields: [businessId], references: [id])
  customer  Customer          @relation(fields: [customerId], references: [id])
  booking   Booking?          @relation(fields: [bookingId], references: [id])
  quote     Quote?            @relation(fields: [quoteId], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@unique([businessId, invoiceNumber])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  serviceId   String?

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model MedicalRecord {
  id                 String   @id @default(cuid())
  businessId         String
  customerId         String
  version            Int      @default(1)
  isCurrent          Boolean  @default(true)
  allergies          String[] @default([])
  contraindications  String[] @default([])
  medications        String[] @default([])
  conditions         String[] @default([])
  skinType           String?
  fitzpatrickScale   String?
  bloodThinners      Boolean  @default(false)
  pregnant           Boolean  @default(false)
  breastfeeding      Boolean  @default(false)
  recentSurgery      String?
  notes              String?
  flagged            Boolean  @default(false)
  flagReason         String?
  consentGiven       Boolean  @default(false)
  consentDate        DateTime?
  recordedById       String?
  createdAt          DateTime @default(now())

  business   Business  @relation(fields: [businessId], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id])
  recordedBy Staff?    @relation("MedicalRecordStaff", fields: [recordedById], references: [id])

  @@unique([customerId, version])
  @@index([customerId])
  @@index([businessId])
  @@map("medical_records")
}

model ClinicalPhoto {
  id           String   @id @default(cuid())
  businessId   String
  customerId   String
  bookingId    String?
  type         String   // BEFORE, AFTER, PROGRESS
  bodyArea     String
  fileUrl      String
  thumbnailUrl String?
  notes        String?
  takenAt      DateTime @default(now())
  takenById    String?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())

  business Business  @relation(fields: [businessId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  booking  Booking?  @relation(fields: [bookingId], references: [id])
  takenBy  Staff?    @relation("PhotoTakenByStaff", fields: [takenById], references: [id])

  beforeComparisons PhotoComparison[] @relation("BeforePhoto")
  afterComparisons  PhotoComparison[] @relation("AfterPhoto")

  @@index([customerId])
  @@index([businessId])
  @@index([bookingId])
  @@map("clinical_photos")
}

model PhotoComparison {
  id            String   @id @default(cuid())
  businessId    String
  customerId    String
  beforePhotoId String
  afterPhotoId  String
  bodyArea      String
  notes         String?
  createdAt     DateTime @default(now())

  business    Business      @relation(fields: [businessId], references: [id])
  customer    Customer      @relation(fields: [customerId], references: [id])
  beforePhoto ClinicalPhoto @relation("BeforePhoto", fields: [beforePhotoId], references: [id])
  afterPhoto  ClinicalPhoto @relation("AfterPhoto", fields: [afterPhotoId], references: [id])

  @@index([customerId])
  @@map("photo_comparisons")
}

model TreatmentPlan {
  id                String    @id @default(cuid())
  businessId        String
  customerId        String
  consultBookingId  String    @unique
  createdById       String
  status            String    @default("DRAFT") // DRAFT | PROPOSED | ACCEPTED | IN_PROGRESS | COMPLETED | CANCELLED
  diagnosis         String?
  goals             String?
  contraindications String?
  totalEstimate     Decimal?  @db.Decimal(10, 2)
  currency          String    @default("USD")
  notes             String?
  proposedAt        DateTime?
  acceptedAt        DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  business       Business           @relation(fields: [businessId], references: [id])
  customer       Customer           @relation(fields: [customerId], references: [id])
  consultBooking Booking            @relation("ConsultPlan", fields: [consultBookingId], references: [id])
  createdBy      Staff              @relation("TreatmentPlanCreator", fields: [createdById], references: [id])
  sessions       TreatmentSession[]

  @@index([customerId])
  @@index([businessId])
  @@map("treatment_plans")
}

model TreatmentSession {
  id              String    @id @default(cuid())
  treatmentPlanId String
  serviceId       String
  bookingId       String?   @unique
  sequenceOrder   Int
  status          String    @default("PENDING") // PENDING | SCHEDULED | COMPLETED | SKIPPED
  scheduledDate   DateTime?
  notes           String?
  completedAt     DateTime?

  treatmentPlan TreatmentPlan @relation(fields: [treatmentPlanId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])
  booking       Booking?      @relation("SessionBooking", fields: [bookingId], references: [id])

  @@index([treatmentPlanId])
  @@map("treatment_sessions")
}

model AftercareProtocol {
  id        String   @id @default(cuid())
  businessId String
  serviceId  String?
  name       String
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business    Business  @relation(fields: [businessId], references: [id])
  service     Service?  @relation(fields: [serviceId], references: [id])
  steps       AftercareStep[]
  enrollments AftercareEnrollment[]

  @@unique([businessId, serviceId])
  @@index([businessId])
  @@map("aftercare_protocols")
}

model AftercareStep {
  id            String  @id @default(cuid())
  protocolId    String
  sequenceOrder Int
  delayHours    Int
  channel       String  @default("WHATSAPP") // WHATSAPP | SMS | EMAIL
  subject       String?
  body          String
  instructions  String?
  isActive      Boolean @default(true)

  protocol AftercareProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId])
  @@map("aftercare_steps")
}

model AftercareEnrollment {
  id          String    @id @default(cuid())
  protocolId  String
  bookingId   String    @unique
  customerId  String
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  protocol AftercareProtocol @relation(fields: [protocolId], references: [id])
  booking  Booking           @relation(fields: [bookingId], references: [id])
  customer Customer          @relation(fields: [customerId], references: [id])
  messages AftercareMessage[]

  @@index([customerId])
  @@map("aftercare_enrollments")
}

model AftercareMessage {
  id           String    @id @default(cuid())
  enrollmentId String
  stepId       String
  scheduledFor DateTime
  sentAt       DateTime?
  status       String    @default("SCHEDULED") // SCHEDULED | SENT | FAILED | CANCELLED
  messageId    String?

  enrollment AftercareEnrollment @relation(fields: [enrollmentId], references: [id])

  @@index([enrollmentId])
  @@index([status, scheduledFor])
  @@map("aftercare_messages")
}

// ── Marketing Command Center Models ──────────────────────────────────

model ABTest {
  id               String    @id @default(cuid())
  businessId       String
  name             String
  description      String?
  status           String    @default("DRAFT") // DRAFT, RUNNING, PAUSED, COMPLETED, CANCELLED
  metric           String    // engagement_rate, click_through_rate, conversion_rate, etc.
  startedAt        DateTime?
  endedAt          DateTime?
  winnerVariantId  String?
  confidence       Float?
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business Business       @relation(fields: [businessId], references: [id])
  variants ABTestVariant[]

  @@index([businessId])
  @@index([businessId, status])
  @@map("ab_tests")
}

model ABTestVariant {
  id              String  @id @default(cuid())
  abTestId        String
  contentDraftId  String?
  variantLabel    String
  impressions     Int     @default(0)
  clicks          Int     @default(0)
  conversions     Int     @default(0)
  engagementScore Float?
  isWinner        Boolean @default(false)
  metadata        Json    @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  abTest       ABTest        @relation(fields: [abTestId], references: [id])
  contentDraft ContentDraft? @relation(fields: [contentDraftId], references: [id])

  @@index([abTestId])
  @@map("ab_test_variants")
}

model RejectionLog {
  id             String   @id @default(cuid())
  businessId     String
  contentDraftId String
  gate           String   // GATE_1, GATE_2, GATE_3, GATE_4
  rejectionCode  String   // R01-R10
  reason         String
  severity       String   @default("MINOR") // MINOR, MAJOR, CRITICAL
  agentId        String?
  reviewedById   String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  business     Business      @relation(fields: [businessId], references: [id])
  contentDraft ContentDraft  @relation(fields: [contentDraftId], references: [id])
  reviewedBy   Staff?        @relation("RejectionLogReviewer", fields: [reviewedById], references: [id])

  @@index([businessId])
  @@index([businessId, contentDraftId])
  @@index([businessId, gate])
  @@map("rejection_logs")
}

model PlatformConfig {
  id              String    @id @default(cuid())
  businessId      String
  platform        String    // INSTAGRAM, TIKTOK, LINKEDIN, YOUTUBE, PINTEREST, TWITTER
  phase           String    @default("LOCKED") // LOCKED, ACTIVE, SCALING
  isEnabled       Boolean   @default(false)
  credentials     Json      @default("{}")
  postingSchedule Json      @default("{}")
  constraints     Json      @default("{}")
  metrics         Json      @default("{}")
  unlockedAt      DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, platform])
  @@index([businessId])
  @@map("platform_configs")
}

model BudgetEntry {
  id          String   @id @default(cuid())
  businessId  String
  category    String   // CONTENT_CREATION, ADVERTISING, TOOLS, FREELANCE, etc.
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  period      String   // MONTHLY, QUARTERLY, ANNUAL, ONE_TIME
  month       Int?     // 1-12
  year        Int?
  isRecurring Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([businessId, category])
  @@map("budget_entries")
}

model EscalationEvent {
  id             String    @id @default(cuid())
  businessId     String
  triggerType    String    // QUALITY_FAILURE, BUDGET_EXCEEDED, AGENT_ERROR, COMPLIANCE, etc.
  severity       String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  title          String
  description    String?
  agentId        String?
  contentDraftId String?
  isResolved     Boolean   @default(false)
  resolvedById   String?
  resolvedAt     DateTime?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())

  business   Business @relation(fields: [businessId], references: [id])
  resolvedBy Staff?   @relation("EscalationResolver", fields: [resolvedById], references: [id])

  @@index([businessId])
  @@index([businessId, isResolved])
  @@index([businessId, severity])
  @@map("escalation_events")
}

// ---------------------------------------------------------------------------
// Message Usage Tracking (Omnichannel billing)
// ---------------------------------------------------------------------------

model MessageUsage {
  id         String @id @default(cuid())
  businessId String
  channel    String // WHATSAPP, INSTAGRAM, FACEBOOK, SMS, EMAIL, WEB_CHAT
  direction  String // INBOUND, OUTBOUND
  date       String // "2026-03-18" format
  count      Int    @default(0)
  segments   Int     @default(0)
  cost       Decimal @default(0)

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, channel, direction, date])
  @@index([businessId])
  @@index([businessId, date])
  @@map("message_usage")
}

model DeviceToken {
  id         String   @id @default(cuid())
  staffId    String
  businessId String
  token      String
  platform   String   // 'ios' | 'android' | 'web'
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([staffId, token])
  @@index([businessId])
  @@index([staffId, isActive])
  @@map("device_tokens")
}

model CustomerReferral {
  id                  String    @id @default(cuid())
  businessId          String
  referrerCustomerId  String
  referredCustomerId  String?
  referralCode        String
  status              String    @default("PENDING") // PENDING, COMPLETED, EXPIRED, CANCELLED
  referrerCreditAmount Float
  refereeCreditAmount  Float
  completedAt         DateTime?
  expiresAt           DateTime?
  bookingId           String?   @unique
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  business            Business  @relation(fields: [businessId], references: [id])
  referrerCustomer    Customer  @relation("ReferrerCustomer", fields: [referrerCustomerId], references: [id])
  referredCustomer    Customer? @relation("ReferredCustomer", fields: [referredCustomerId], references: [id])
  booking             Booking?  @relation(fields: [bookingId], references: [id])

  credits             CustomerCredit[]

  @@unique([businessId, referrerCustomerId, referredCustomerId])
  @@index([businessId])
  @@index([referrerCustomerId])
  @@index([referredCustomerId])
  @@index([referralCode])
  @@index([businessId, status])
  @@map("customer_referrals")
}

model CustomerCredit {
  id              String    @id @default(cuid())
  businessId      String
  customerId      String
  amount          Float
  remainingAmount Float
  source          String    // REFERRAL_GIVEN, REFERRAL_RECEIVED, MANUAL
  referralId      String?
  expiresAt       DateTime?
  redeemedAt      DateTime?
  createdAt       DateTime  @default(now())

  business        Business  @relation(fields: [businessId], references: [id])
  customer        Customer  @relation(fields: [customerId], references: [id])
  referral        CustomerReferral? @relation(fields: [referralId], references: [id])
  redemptions     CreditRedemption[]

  @@index([businessId, customerId])
  @@index([customerId, source])
  @@index([expiresAt])
  @@map("customer_credits")
}

model CreditRedemption {
  id              String    @id @default(cuid())
  creditId        String
  bookingId       String
  amount          Float
  createdAt       DateTime  @default(now())

  credit          CustomerCredit @relation(fields: [creditId], references: [id])
  booking         Booking        @relation(fields: [bookingId], references: [id])

  @@index([creditId])
  @@index([bookingId])
  @@map("credit_redemptions")
}
