# Database
# For connection pooling at scale, append: ?connection_limit=10&pool_timeout=30
# With PgBouncer: use ?pgbouncer=true&connection_limit=10
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking_os?schema=public"

# JWT — IMPORTANT: Change secrets to strong random values in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Webhook — Set to enable HMAC signature verification on inbound webhooks
# Required in production (NODE_ENV=production)
# WEBHOOK_SECRET=""

# CORS — Comma-separated origins allowed to access the API
# Required in production. MUST include both web and admin URLs.
# CORS_ORIGINS="http://localhost:3000,http://localhost:3002"
# Production: "https://businesscommandcentre.com,https://admin.businesscommandcentre.com"

# API
API_PORT=3001
API_URL="http://localhost:3001"

# Web
WEB_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# Admin Console
# ADMIN_PORT=3002
# NEXT_PUBLIC_ADMIN_URL=https://admin.businesscommandcentre.com
# NEXT_PUBLIC_CUSTOMER_APP_URL=https://businesscommandcentre.com
# NEXT_PUBLIC_SENTRY_DSN_ADMIN=  # Separate Sentry DSN for admin error tracking

# Simulator
SIMULATOR_PORT=3003

# AI — Claude API key for AI features (intent detection, reply suggestions, booking assistant)
# ANTHROPIC_API_KEY=""

# WhatsApp Cloud API — Required for production WhatsApp messaging
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_VERIFY_TOKEN=""

# Messaging provider: "mock" (default for dev) or "whatsapp-cloud" (production)
# MESSAGING_PROVIDER="mock"

# Instagram DM — Required for production Instagram messaging
# INSTAGRAM_APP_ID=""
# INSTAGRAM_APP_SECRET=""
# INSTAGRAM_VERIFY_TOKEN=""
# INSTAGRAM_CLIENT_SECRET=""

# Email — Transactional emails (booking confirmations, password reset, etc.)
# Provider: "resend" (recommended), "sendgrid", or "none" (default, logs only)
# EMAIL_PROVIDER="none"
# EMAIL_API_KEY=""
# EMAIL_FROM="Booking OS <noreply@yourdomain.com>"

# Stripe — Required for billing and payment features
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# Legacy (backward compat): STRIPE_PRICE_ID_BASIC, STRIPE_PRICE_ID_PRO
# New 3-tier pricing:
# STRIPE_PRICE_ID_STARTER_MONTHLY=""
# STRIPE_PRICE_ID_STARTER_ANNUAL=""
# STRIPE_PRICE_ID_PROFESSIONAL_MONTHLY=""
# STRIPE_PRICE_ID_PROFESSIONAL_ANNUAL=""
# STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=""
# STRIPE_PRICE_ID_ENTERPRISE_ANNUAL=""

# Calendar Sync — OAuth credentials for external calendar integration
# Generate encryption key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CALENDAR_ENCRYPTION_KEY=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""

# Push Notifications (Firebase Cloud Messaging) — Required for mobile push notifications
# FCM_PROJECT_ID=""
# FCM_SERVICE_ACCOUNT_KEY=""    # JSON service account key (stringified)

# Redis — Required for BullMQ job queues, WebSocket multi-instance, and caching (50+ clients)
# REDIS_URL="redis://localhost:6379"

# Web Chat uses Socket.IO WebSocket on the /web-chat namespace — no additional env vars required

# Sentry — Error tracking
# SENTRY_DSN=""                    # API
# NEXT_PUBLIC_SENTRY_DSN=""        # Web app
# NEXT_PUBLIC_SENTRY_DSN_ADMIN=""  # Admin console (separate DSN)

# PostHog — Product analytics (web app only)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Database Backups
# BACKUP_DIR="./backups"
# BACKUP_RETENTION_DAYS=7
# AWS_S3_BUCKET=""

# SSL / Let's Encrypt
# DOMAIN=""
# CERT_EMAIL=""
# CERT_STAGING="true"
# WEBROOT_DIR="./certbot/webroot"

# Logging — Level: trace, debug, info, warn, error, fatal
# LOG_LEVEL="info"

# Monitoring — Webhook for health check alerts (Slack/Discord)
# ALERT_WEBHOOK_URL=""
# CHECK_INTERVAL=60
# FAILURE_THRESHOLD=3

# Environment
NODE_ENV="development"
